<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0f1b2d">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="WCQF">
  <meta name="description" content="World Cup Quant Fund — picks y análisis del Mundial 2026">
  <title>WCQF Terminal · Mundial 2026</title>
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/icon-192.png">
  <link rel="icon" type="image/png" href="/icons/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>

<!-- ── Splash ──────────────────────────────────────────────────── -->
<div id="splash">
  <div class="sp-logo">WCQF</div>
  <div class="sp-sub">WORLD CUP QUANT FUND · 2026</div>
  <div class="sp-bar"><div class="sp-fill"></div></div>
</div>

<!-- ── Header ──────────────────────────────────────────────────── -->
<header class="app-header">
  <div class="header-brand">
    <div>
      <div class="header-logo">WCQF⚡</div>
      <div class="header-sub">MUNDIAL 2026</div>
    </div>
  </div>
  <div class="header-right">
    <span id="clock">--:--:--</span>
    <button id="refresh-btn" title="Actualizar Betfair">⟳</button>
  </div>
</header>

<!-- ── App body ────────────────────────────────────────────────── -->
<main class="app-body">

  <!-- PICKS -->
  <section class="tab-panel active" id="tab-picks"></section>

  <!-- PARTIDOS -->
  <section class="tab-panel" id="tab-partidos"></section>

  <!-- FUTUROS -->
  <section class="tab-panel" id="tab-futuros"></section>

  <!-- VALOR -->
  <section class="tab-panel" id="tab-valor"></section>

  <!-- INFO -->
  <section class="tab-panel" id="tab-info"></section>

</main>

<!-- ── Bottom nav ──────────────────────────────────────────────── -->
<nav class="bottom-nav">
  <button class="nav-btn active" data-tab="picks">
    <span class="nav-icon">⭐</span>PICKS
  </button>
  <button class="nav-btn" data-tab="partidos">
    <span class="nav-icon">⚽</span>PARTIDOS
  </button>
  <button class="nav-btn" data-tab="futuros">
    <span class="nav-icon">🏆</span>FUTUROS
  </button>
  <button class="nav-btn" data-tab="valor">
    <span class="nav-icon">📈</span>VALOR
  </button>
  <button class="nav-btn" data-tab="info">
    <span class="nav-icon">⚙️</span>INFO
  </button>
</nav>

<!-- ── Scripts ─────────────────────────────────────────────────── -->
<script>
  // Hide splash after animation
  setTimeout(() => {
    const s = document.getElementById('splash');
    if (s) { s.style.transition = 'opacity .4s'; s.style.opacity = '0'; setTimeout(() => s.remove(), 400); }
  }, 1400);
  // Register service worker
  if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js').catch(()=>{});
</script>
<script type="module" src="/js/app.js"></script>

</body>
</html>
